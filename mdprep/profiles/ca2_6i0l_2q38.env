# CA II + 2Q38 (PDB 6I0L) — config.sh'e kopyalanacak örnek değerler
# Yeni klasörde: bu satırları mdprep/config.sh ilgili bölümlere taşıyın.
# HSD resid'lerini 6I0L PDB'nizden PyMOL/VMD ile DOĞRULAYIN.

METAL_ENZYME="yes"
METAL_CHAIN="A"
METAL_ION_RESNAME="ZN"
METAL_HSD_RESIDUES="94 96 119"    # ← 6I0L için kontrol edin

CHECK_BINDING="yes"
CHECK_BINDING_STRICT="no"
CHECK_LIG_RESNAME="2Q38"          # CGenFF / lig.itp moleculetype

REF_TEMP="310"
PROD_NS="300"
INTERACTIVE_MD="yes"
LOCAL_NVT_RUN="no"                # MD'yi run_local_md.sh ile elle
LOCAL_NPT_RUN="no"
LOCAL_PROD_RUN="no"

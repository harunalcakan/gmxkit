# Per-project overrides (optional). Loaded when you run gmxkit from this folder.

# --- Standard protein–ligand (default) ---
# METAL_ENZYME="no"

# --- Metalloenzyme (optional) ---
# METAL_ENZYME="yes"
# METAL_CHAIN="A"
# METAL_ION_RESNAME="ZN"
# METAL_HSD_RESIDUES="94 96 119"   # your PDB — see mdprep/profiles/

# LIG_RESNAME="LIG"                # must match ligand.mol2 molecule name
# CHECK_LIG_RESNAME="LIG"          # analysis/binding; defaults to LIG_RESNAME
# REF_TEMP="310"
# PROD_NS="300"
